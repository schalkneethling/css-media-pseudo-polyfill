{
  "name": "css-media-pseudo-polyfill",
  "version": "1.0.0",
  "description": "A CSS polyfill for media pseudo-classes (:playing, :paused, :seeking, :buffering, :stalled, :muted)",
  "keywords": [
    "audio",
    "buffering",
    "css",
    "media",
    "muted",
    "paused",
    "playing",
    "polyfill",
    "pseudo-classes",
    "seeking",
    "video"
  ],
  "homepage": "https://github.com/schalkneethling/css-media-pseudo-polyfill",
  "bugs": {
    "url": "https://github.com/schalkneethling/css-media-pseudo-polyfill/issues"
  },
  "license": "MIT",
  "author": "Schalk Neethling",
  "repository": {
    "type": "git",
    "url": "https://github.com/schalkneethling/css-media-pseudo-polyfill"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./fn": "./dist/fn.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build",
    "prepare": "vp config"
  },
  "dependencies": {
    "css-tree": "^3.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/css-tree": "^2.3.10",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "bumpp": "^11.0.1",
    "typescript": "^5.9.3",
    "vite": "latest",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
